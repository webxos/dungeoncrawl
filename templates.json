# ------------------------------------------------------------
# 2. EXPANSION FUNCTIONS
# ------------------------------------------------------------
def expand_list(base_list, target_min=2000):
    """Expand a list of strings to at least target_min items."""
    if len(base_list) >= target_min:
        return base_list[:]
    expanded = base_list[:]
    suffixes = [" (echoing)", " (dusty)", " (ancient)", " (whispering)", " (shadowy)"]
    while len(expanded) < target_min:
        for s in base_list:
            if len(expanded) >= target_min:
                break
            new_s = s + random.choice(suffixes)
            if new_s not in expanded:
                expanded.append(new_s)
    return expanded[:target_min]

def expand_monsters(base_list, target=500):
    if len(base_list) >= target:
        return base_list[:]
    monsters = base_list[:]
    prefixes = ["Shadow", "Fire", "Ice", "Venom", "Ancient", "Elder", "Cursed", "Raging", "Void"]
    while len(monsters) < target:
        base = random.choice(base_list)
        new = copy.deepcopy(base)
        new["name"] = random.choice(prefixes) + " " + base["name"]
        new["base_hp"] = int(base["base_hp"] * random.uniform(0.8, 1.5))
        new["base_attack"] = int(base["base_attack"] * random.uniform(0.8, 1.5))
        new["base_defense"] = int(base["base_defense"] * random.uniform(0.8, 1.5))
        new["xp"] = int(base["xp"] * random.uniform(0.8, 1.5))
        monsters.append(new)
    return monsters[:target]

def expand_items(base_list, target=1000):
    if len(base_list) >= target:
        return base_list[:]
    items = base_list[:]
    prefixes = ["Iron", "Steel", "Bronze", "Silver", "Golden", "Crystal", "Obsidian", "Mithril"]
    while len(items) < target:
        base = random.choice(base_list)
        new = copy.deepcopy(base)
        new["name"] = random.choice(prefixes) + " " + base["name"]
        new["value"] = int(base["value"] * random.uniform(0.8, 1.5))
        if "bonus" in new:
            new["bonus"] = int(base["bonus"] * random.uniform(0.8, 1.5))
        items.append(new)
    return items[:target]

def expand_ground_loot(base_loot):
    expanded = {}
    for zone, data in base_loot.items():
        items = data["items"]
        chances = data["chances"]
        new_items = items[:]
        for _ in range(200):
            base_item = random.choice(items)
            new_item = copy.deepcopy(base_item)
            new_item["name"] = random.choice(["Strange", "Glowing", "Faint", "Cracked"]) + " " + new_item["name"]
            new_items.append(new_item)
        new_chances = chances * (len(new_items) // len(chances) + 1)
        new_chances = new_chances[:len(new_items)]
        total = sum(new_chances)
        new_chances = [c / total for c in new_chances]
        expanded[zone] = {"items": new_items, "chances": new_chances}
    return expanded

def expand_quests(base_list, target=200):
    if len(base_list) >= target:
        return base_list[:]
    quests = base_list[:]
    targets = ["Goblin", "Skeleton", "Orc", "Dragon", "Lich", "Troll", "Spider"]
    while len(quests) < target:
        q = copy.deepcopy(random.choice(base_list))
        q["id"] = f"q_{random.randint(1000,9999)}"
        verb = random.choice(["Slay", "Collect", "Find", "Defeat"])
        noun = random.choice(targets)
        q["name"] = f"{verb} {noun}"
        obj_type = random.choice(["kill", "collect", "explore"])
        obj_target = random.choice(targets)
        required = random.randint(1, 5)
        q["objectives"] = [{"type": obj_type, "target": obj_target, "current": 0, "required": required}]
        quests.append(q)
    return quests[:target]

def expand_lore(base_list, target=500):
    if len(base_list) >= target:
        return base_list[:]
    lore = base_list[:]
    topics = [
        "The dungeon was built by the dwarves.", "A great battle was fought here centuries ago.",
        "The Lich was once a righteous king.", "Three heroes sealed the evil long ago.",
        "The dungeon shifts its layout every century.", "The Dungeon Heart beats once per hour."
    ]
    while len(lore) < target:
        new_lore = random.choice(topics) + " " + random.choice(["Legends say...", "You recall...", "The walls whisper..."])
        lore.append(new_lore)
    return lore[:target]

def build_mega_expanded():
    templates = copy.deepcopy(BASE)
    # Expand all list‑based keys
    for key in ["room_descriptions", "ambient", "action_responses", "monster_encounters",
                "loot_descriptions", "combat_responses", "trap_responses", "npc_dialogues",
                "riddles", "prophecies", "magical_events", "model_unavailable"]:
        if key in templates:
            templates[key] = expand_list(templates[key], 2000)
    # Expand monsters, items, ground loot, quests, lore
    templates["monsters"] = expand_monsters(templates["monsters"], 500)
    templates["items"] = expand_items(templates["items"], 1000)
    templates["ground_loot"] = expand_ground_loot(templates["ground_loot"])
    templates["quest_templates"] = expand_quests(templates["quest_templates"], 200)
    templates["lore_fragments"] = expand_lore(templates["lore_fragments"], 500)
    # Expand fallback messages
    for tool, msgs in templates.get("nli_fallback_messages", {}).items():
        if isinstance(msgs, list):
            new_msgs = msgs[:]
            for _ in range(100):
                for m in msgs:
                    new_m = m + " " + random.choice(["The dungeon hums.", "Shadows flicker.", "You feel a chill."])
                    new_msgs.append(new_m)
            templates["nli_fallback_messages"][tool] = new_msgs[:200]
    return templates

# ------------------------------------------------------------
# 3. MAIN
# ------------------------------------------------------------
if __name__ == "__main__":
    print("Generating full templates.json ...")
    expanded = build_mega_expanded()
    with open("templates.json", "w") as f:
        json.dump(expanded, f, indent=2)
    total_items = sum(
        len(v) if isinstance(v, list) else
        sum(len(sv) if isinstance(sv, list) else 1 for sv in v.values()) if isinstance(v, dict) else 1
        for v in expanded.values()
    )
    print(json.dumps({"status": "ok", "items": total_items}))
    print("templates.json created successfully.")
