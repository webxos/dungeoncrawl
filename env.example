# === CORE FIX: disable LLM completely ===
ALWAYS_USE_LLM=false
LLM_FALLBACK_ENABLED=false
NARRATOR_ENABLED=false

# Optional – keep quest generation if you want static quests
QUEST_GEN_ENABLED=true      # uses template quests, not LLM
DEEP_STORY_MODE=false
MODEL_TIER=small

# Ollama (unused, but keep as fallback)
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
MODEL=qwen2.5:0.5b

# Python & game paths
PYTHON_CMD=python3
TEMPLATES_FILE=./templates.json
CRAFTING_RECIPES_FILE=./crafting_recipes.json

# Misc
DEBUG=false
JSON_ERROR_LOG=./dungeoncrawl_errors.ndjson
